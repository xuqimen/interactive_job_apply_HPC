#!/usr/bin/env bash
# interact-job - Apply for an interactive job on a DonauKit-managed cluster.
#
# Author: Qimen Xu <qimenxu@foxmail.com>
# Written with Claude Code (https://claude.ai/claude-code)

VERSION="1.0.0"
DEFAULT_QUEUE="q_genuser"
DEFAULT_NODES=1
JOB_NAME="interQX"
RPN=608

usage() {
    cat <<EOF
Usage: interact-job [OPTION]...

Apply for an interactive job on the cluster via DonauKit (dsub).

Options:
  -n, --nodes NUM       number of nodes to request (default: $DEFAULT_NODES)
  -q, --queue QUEUE     queue to submit to (default: $DEFAULT_QUEUE)
      --name NAME       job name (default: $JOB_NAME)
      --rpn NUM         max replicas per node (default: $RPN)
  -h, --help            display this help and exit
      --version         output version information and exit

Examples:
  interact-job                       # 1 node on $DEFAULT_QUEUE
  interact-job -n 2                  # 2 nodes on $DEFAULT_QUEUE
  interact-job -q q_gpu              # 1 node on q_gpu
  interact-job -n 4 -q q_large       # 4 nodes on q_large
EOF
}

NODES=$DEFAULT_NODES
QUEUE=$DEFAULT_QUEUE

OPTS=$(getopt -o n:q:h --long nodes:,queue:,name:,rpn:,help,version -n "$(basename "$0")" -- "$@") || {
    echo "Try '$(basename "$0") --help' for more information." >&2
    exit 1
}
eval set -- "$OPTS"

while true; do
    case "$1" in
        -n|--nodes)   NODES="$2";    shift 2 ;;
        -q|--queue)   QUEUE="$2";    shift 2 ;;
        --name)       JOB_NAME="$2"; shift 2 ;;
        --rpn)        RPN="$2";      shift 2 ;;
        -h|--help)    usage; exit 0 ;;
        --version)
            echo "interact-job $VERSION"
            echo ""
            echo "Written by Qimen Xu."
            exit 0
            ;;
        --)           shift; break ;;
        *)            break ;;
    esac
done

CMD=(dsub -n "$JOB_NAME" -nn "$NODES" -rpn "$RPN" -q "$QUEUE" -I bash)
echo "Requesting interactive job: nodes=$NODES, queue=$QUEUE, rpn=$RPN, name=$JOB_NAME"
echo "${CMD[*]}"
exec "${CMD[@]}"
